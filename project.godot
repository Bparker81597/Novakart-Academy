; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Novakart Academy"
run/main_scene="res://scenes/main/MainMenu.tscn"
config/features=PackedStringArray("4.6")

[autoload]

ContentCatalog="*res://scripts/global/content_catalog.gd"
GameState="*res://scripts/global/game_state.gd"
SaveManager="*res://scripts/global/save_manager.gd"
AudioManager="*res://scripts/global/audio_manager.gd"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"blaze_bolt": "res://experiments/open_source_tests/dialogic/characters/blaze_bolt.dch",
"dash_rocket": "res://experiments/open_source_tests/dialogic/characters/dash_rocket.dch",
"finn_tide": "res://experiments/open_source_tests/dialogic/characters/finn_tide.dch",
"nova_spark": "res://experiments/open_source_tests/dialogic/characters/nova_spark.dch"
}
directories/dtl_directory={
"academy_hello": "res://experiments/open_source_tests/dialogic/timelines/academy_hello.dtl",
"blaze_test": "res://experiments/open_source_tests/dialogic/timelines/blaze_test.dtl",
"dash_test": "res://experiments/open_source_tests/dialogic/timelines/dash_test.dtl",
"finn_test": "res://experiments/open_source_tests/dialogic/timelines/finn_test.dtl",
"nova_test": "res://experiments/open_source_tests/dialogic/timelines/nova_test.dtl"
}
layout/style_directory={}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

